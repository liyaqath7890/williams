NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:5173
# Production example:
# CLIENT_ORIGIN=https://your-frontend.example.com
DATABASE_URL=postgres://postgres:postgres@localhost:5432/aegis
DB_SSL=false
DB_SYNC=true
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace-with-strong-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d
REFRESH_COOKIE_NAME=aegis_refresh_token
CLOUDINARY_CLOUD_NAME=replace-with-cloudinary-name
CLOUDINARY_API_KEY=replace-with-cloudinary-key
CLOUDINARY_API_SECRET=replace-with-cloudinary-secret
REDIS_URL=redis://127.0.0.1:6379
FIREBASE_PROJECT_ID=replace-with-firebase-project-id
